# Environment variables — copy this file to .env and fill in values.
# This project runs 100% offline and requires no cloud API keys.
#
#   cp .env.example .env

# ── Ollama host ──────────────────────────────────────────────────────────────
# Override if Ollama runs on a different host or port.
# Docker users: set this to http://host.docker.internal:11434
# OLLAMA_HOST=http://localhost:11434

# ── Proxy bypass (optional) ──────────────────────────────────────────────────
# Automatically set in backend/main.py; override here only if needed.
# NO_PROXY=huggingface.co,*.huggingface.co,localhost,127.0.0.1
# no_proxy=huggingface.co,*.huggingface.co,localhost,127.0.0.1

# ── FastAPI / Uvicorn settings (optional) ────────────────────────────────────
# PORT is automatically set by PaaS platforms (Render, Railway, Heroku, etc.)
# PORT=8000
# HOST=0.0.0.0

# ── HuggingFace (optional) ───────────────────────────────────────────────────
# Only needed if you hit rate limits downloading the embedding model on first run.
# HUGGINGFACE_TOKEN=hf_...
